{
  "permissions": {
    "allow": [
      "Bash(dotnet restore:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet clean:*)",
      "Bash(dotnet publish:*)",
      "Bash(dotnet sln:*)",
      "Bash(dotnet --version)",
      "Bash(dotnet --info)",
      "Bash(pwsh:*)",
      "Bash(powershell:*)",
      "Bash(python -m http.server:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)"
    ],
    "ask": [],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ./.claude/hooks/post_edit.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& './init.ps1'; if ($LASTEXITCODE -ne 0) { exit 2 }\""
          }
        ]
      }
    ]
  }
}
